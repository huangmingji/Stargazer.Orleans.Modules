{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  
  "Serilog": {
    "Using":  [ "Serilog.Sinks.Console", "Serilog.Sinks.File", "Serilog.Sinks.Seq" ],
    "MinimumLevel": "Debug",
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args":
        {
          "path": "Logs/log.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "fileSizeLimitBytes": 31457280,
          "rollOnFileSizeLimit": true,
          "buffered": true
        }
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341"
        }
      }
    ]
  },
  "ConnectionStrings": {
    "Default": "server=127.0.0.1;port=5432;Database=orleans;uid=postgres;pwd=123456",
    "ObjectStorage": "server=127.0.0.1;port=5432;Database=orleans;uid=postgres;pwd=123456",
    "Redis": "127.0.0.1:6379"
  },
  "Orleans": {
    "ClusterId": "stargazer",
    "ServiceId": "stargazer-app",
    "SiloPort": 11112,
    "GatewayPort": 30001
  },
  "Storage": {
    "Provider": "local",
    "DefaultExpiryMinutes": 60,

    "Local": {
      "BasePath": "/data/objects"
    },

    "Aliyun": {
      "Endpoint": "oss-cn-hangzhou.aliyuncs.com",
      "AccessKeyId": "your-access-key",
      "AccessKeySecret": "your-secret",
      "BucketName": "your-bucket"
    },

    "Aws": {
      "Region": "us-east-1",
      "AccessKeyId": "your-access-key",
      "SecretAccessKey": "your-secret",
      "BucketName": "your-bucket"
    },

    "Azure": {
      "ConnectionString": "your-connection-string",
      "ContainerName": "your-container"
    },

    "Tencent": {
      "Region": "ap-guangzhou",
      "SecretId": "your-secret-id",
      "SecretKey": "your-secret-key",
      "BucketName": "your-bucket"
    },

    "Minio": {
      "Endpoint": "localhost:9000",
      "AccessKey": "your-access-key",
      "SecretKey": "your-secret-key",
      "BucketName": "your-bucket",
      "UseSSL": false
    }
  }
}
