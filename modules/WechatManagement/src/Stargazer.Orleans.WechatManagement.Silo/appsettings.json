{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Serilog": {
    "Using":  [ "Serilog.Sinks.Console", "Serilog.Sinks.File", "Serilog.Sinks.Seq" ],
    "MinimumLevel": "Debug",
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args":
        {
          "path": "Logs/log.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "fileSizeLimitBytes": 31457280,
          "rollOnFileSizeLimit": true,
          "buffered": true
        }
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341"
        }
      }
    ]
  },
  "ConnectionStrings": {
    "Default": "server=127.0.0.1;port=5432;Database=app;uid=postgres;pwd=123456",
    "Wechat": "server=127.0.0.1;port=5432;Database=orleans;uid=postgres;pwd=123456",
    "Redis": "127.0.0.1:6379",
  },
  "JwtSettings": {
    "SecretKey": "StargazerSecretKey2026VeryLongAndSecureKeyForJwtTokenGeneration",
    "Issuer": "Stargazer.Orleans",
    "Audience": "Stargazer.Orleans",
    "ExpiryMinutes": 60,
    "RefreshTokenExpiryDays": 7
  },
  "Orleans": {
    "ClusterId": "stargazer",
    "ServiceId": "stargazer-app",
    "SiloPort": 11114,
    "GatewayPort": 30003
  }
}
